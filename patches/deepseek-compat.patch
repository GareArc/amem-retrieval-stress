+class DeepSeekController(BaseLLMController):
+    """LLM controller for DeepSeek API.
+
+    DeepSeek uses an OpenAI-compatible API but does not support
+    ``response_format: json_schema``.  This controller translates that to
+    ``{"type": "json_object"}`` and strips any markdown code-fences that
+    DeepSeek sometimes wraps around JSON responses.
+
+    Also applies an IPv4-only socket patch required on some Linux hosts where
+    DeepSeek's endpoint is unreachable over IPv6.
+
+    Args:
+        model: Model name (default: ``"deepseek-chat"``).
+        api_key: DeepSeek API key.  Falls back to ``OPENAI_API_KEY`` env var.
+        base_url: API base URL (default: ``"https://api.deepseek.com"``).
+    """
+
+    def __init__(
+        self,
+        model: str = "deepseek-chat",
+        api_key: Optional[str] = None,
+        base_url: str = "https://api.deepseek.com",
+    ):
+        try:
+            from openai import OpenAI
+        except ImportError:
+            raise ImportError("OpenAI package not found. Install it with: pip install openai")
+
+        if api_key is None:
+            api_key = os.getenv("OPENAI_API_KEY")
+        if api_key is None:
+            raise ValueError("DeepSeek API key not found. Set OPENAI_API_KEY environment variable.")
+
+        _enable_ipv4_only()
+
+        self.model = model
+        self.client = OpenAI(api_key=api_key, base_url=base_url)
+        self.token_usage = {"prompt_tokens": 0, "completion_tokens": 0, "total_tokens": 0}
+
+    def get_completion(
+        self,
+        prompt: str,
+        response_format: dict = None,
+        temperature: float = 1.0,
+        max_tokens: int = None,
+    ) -> str:
+        # DeepSeek only supports {"type": "json_object"}, not json_schema.
+        if response_format and response_format.get("type") == "json_schema":
+            api_response_format = {"type": "json_object"}
+        else:
+            api_response_format = response_format
+
+        kwargs = {
+            "model": self.model,
+            "messages": [
+                {"role": "system", "content": "You must respond with a JSON object."},
+                {"role": "user", "content": prompt},
+            ],
+            "temperature": temperature,
+        }
+        if api_response_format is not None:
+            kwargs["response_format"] = api_response_format
+        if max_tokens is not None:
+            kwargs["max_tokens"] = max_tokens
+
+        response = self.client.chat.completions.create(**kwargs)
+        if response.usage:
+            self.token_usage["prompt_tokens"] += response.usage.prompt_tokens
+            self.token_usage["completion_tokens"] += response.usage.completion_tokens
+            self.token_usage["total_tokens"] += response.usage.total_tokens
+
+        content = response.choices[0].message.content
+
+        # Strip markdown code fences that DeepSeek sometimes adds
+        md_match = re.search(r"```(?:json)?\s*(\{.*?\})\s*```", content, re.DOTALL)
+        if md_match:
+            content = md_match.group(1).strip()
+
+        return content
+
